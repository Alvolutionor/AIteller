# AIteller Environment Variables
# Copy this file to .env and fill in your values.
# All variables use ${VAR_NAME} substitution in config/config.yaml.

# ── LLM API Keys (at least one required) ──
CLAUDE_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── Reddit API (optional, for Reddit collector) ──
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Twitter/X (optional, for Twitter collector) ──
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# ── Notification Channels (all optional) ──
SLACK_WEBHOOK_URL=
WECHAT_WEBHOOK_URL=
EMAIL_SENDER=
EMAIL_PASSWORD=

# ── System (optional) ──
# Path to git bash executable (Windows only, for claude CLI integration)
# CLAUDE_CODE_GIT_BASH_PATH=C:\Program Files\Git\bin\bash.exe
# Python executable path (used by run.bat / setup_scheduler.bat)
# PYTHON_PATH=python
